{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/student-ai",
      "destination": "/api/student-ai.ts"
    },
    {
      "source": "/api/teacher-ai",
      "destination": "/api/teacher-ai.ts"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
